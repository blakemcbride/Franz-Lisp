#!/bin/sh
# lispconf -- configure the Franz Lisp source tree for a target platform.
#
# This is a stripped-down rewrite of the original csh script; the
# original supported vax/tahoe/68k/sun/dual/pixel/mc500/lisa/i386/vms
# variants and used cvt.awk (which was missing from the distribution)
# to splice ifdef-style markers in the Makefiles. With only one
# platform supported (linux_x86_64), this reduces to writing
# franz/h/lconf.h.
#
# Usage:  ./lispconf linux_x86_64

set -eu

case "${1:-}" in
    linux_x86_64) ;;
    "")
        echo "usage: $0 linux_x86_64" >&2
        exit 1 ;;
    *)
        echo "$0: unsupported target '$1'" >&2
        echo "    only 'linux_x86_64' is supported in this port." >&2
        exit 1 ;;
esac

cat > franz/h/lconf.h <<EOF
/* this file created by ./lispconf */
#define linux_x86_64 1
EOF

echo "lispconf: wrote franz/h/lconf.h for target linux_x86_64"
echo "lispconf: (top-level Makefile already has Mach=linux_x86_64)"
